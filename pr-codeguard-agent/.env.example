# =============================================================================
# PR-CodeGuard Agent Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- GitLab Connection ---
GITLAB_URL=http://your-gitlab-instance:80
GITLAB_API_TOKEN=your-personal-access-token
WEBHOOK_SECRET=your-webhook-secret

# --- Server ---
HOST=0.0.0.0
PORT=8082

# --- AI Engine (optional) ---
# Enable AI-enhanced code review comments
AI_ENABLED=false
AI_API_KEY=
AI_API_BASE=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# --- Scan Engines ---
ENGINES_SECRETS_ENABLED=true
ENGINES_SAST_ENABLED=true
ENGINES_IAC_ENABLED=true
ENGINES_BEST_PRACTICE_ENABLED=true
ENGINES_TRIVY_ENABLED=true

# --- Trivy Scanner ---
# Path to Trivy binary (auto-discovered if empty)
TRIVY_PATH=
# Scanners: vuln (SCA), secret, misconfig (IaC), license
TRIVY_SCANNERS=vuln,secret,misconfig
TRIVY_SEVERITY_THRESHOLD=MEDIUM
TRIVY_CACHE_DIR=./data/trivy
# Offline mode: skip DB update — uses local cache for air-gapped environments
TRIVY_OFFLINE=true
# Timeout in seconds for Trivy filesystem scan
TRIVY_TIMEOUT=300

# --- Knowledge Base ---
KNOWLEDGE_ENABLED=true
KNOWLEDGE_DB_PATH=./data/knowledge.db
CHROMA_PERSIST_DIR=./data/chroma

# --- Auto Discovery ---
AUTO_DISCOVERY_ENABLED=true

# --- Alerts / Notifications (optional) ---
ALERT_ENABLED=true
ALERT_SEVERITY_THRESHOLD=critical

# DingTalk
ALERT_DINGTALK_WEBHOOK=
ALERT_DINGTALK_SECRET=

# Slack
ALERT_SLACK_WEBHOOK=

# SMTP Email
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_USE_TLS=true
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
